# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# How often to check for new emails (seconds)
POLL_INTERVAL_SECONDS=300

# Gmail label applied to emails once they've been processed
PROCESSED_LABEL=Greenguard-Processed

# Timezone for reading your Google Calendar (used to find open slots)
# Common values: America/New_York, America/Chicago, America/Denver, America/Los_Angeles
CALENDAR_TIMEZONE=America/New_York

# Google Maps API key — enable "Distance Matrix API" in Google Cloud Console
GOOGLE_MAPS_API_KEY=

# Starting address for daily route distance calculations (your depot/home base)
DEPOT_ADDRESS=1519 Parkway Austin TX 78703

# Cal.com API key — cal.com/settings/developer/api-keys
CALCOM_API_KEY=

# ---------------------------------------------------------------------------
# Stripe — stripe.com/dashboard
# ---------------------------------------------------------------------------

# Secret key — use sk_test_... for test mode, sk_live_... for production
STRIPE_SECRET_KEY=

# Webhook signing secret — Stripe Dashboard → Developers → Webhooks → signing secret
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Optional — Gmail push notifications (real-time instead of polling)
# Leave blank to use polling mode (default)
# See push.py for one-time Google Cloud setup instructions (~5 min)
# ---------------------------------------------------------------------------
PUBSUB_PROJECT_ID=
PUBSUB_SUBSCRIPTION_ID=gmail-agent-sub
PUBSUB_TOPIC_NAME=projects/YOUR_PROJECT_ID/topics/gmail-notifications

# Email address for daily route delivery
ROUTE_EMAIL=admin@greenguard-usa.com

# ---------------------------------------------------------------------------
# Twilio — SMS appointment reminders, review requests, payment alerts
# console.twilio.com → Account → API Keys (or Account SID on dashboard)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15125550001

# Admin cell — receives SMS alerts on payment failures
ADMIN_SMS_NUMBER=+15125604129

# ---------------------------------------------------------------------------
# Billing
# ---------------------------------------------------------------------------

# Days after appointment before draft invoice is finalized and sent (default: 5)
BILLING_DELAY_DAYS=5

# ---------------------------------------------------------------------------
# Biogents Pro — biogentspro.com browser automation (Playwright)
# ---------------------------------------------------------------------------

# Login credentials for biogentspro.com account
BIOGENTS_EMAIL=
BIOGENTS_PASSWORD=

# Comma-separated SKU identifiers to monitor for inventory (partial match OK)
# Example: BIOGENTS_SKUS=bg-pro,bg-mosquitaire,bg-sentinel
BIOGENTS_SKUS=

# Per-SKU reorder thresholds and quantities
# Replace <SKU> with the uppercase, underscored SKU (e.g. BG_PRO for bg-pro)
# Reorder when Biogents stock <= threshold; order this many units
# BIOGENTS_REORDER_THRESHOLD_<SKU>=3
# BIOGENTS_REORDER_QTY_<SKU>=5
# Global fallbacks (used when per-SKU vars are not set):
BIOGENTS_REORDER_THRESHOLD=3
BIOGENTS_REORDER_QTY=5

# Warehouse address for restock orders (defaults to DEPOT_ADDRESS if not set)
BIOGENTS_WAREHOUSE_ADDRESS=1519 Parkway Austin TX 78703
BIOGENTS_WAREHOUSE_CITY=Austin
BIOGENTS_WAREHOUSE_STATE=TX
BIOGENTS_WAREHOUSE_ZIP=78703

# Comma-separated list of Biogents SKUs that should trigger drop-ship on Stripe checkout
# These are matched against Stripe line item names/price IDs
BIOGENTS_SKUS=
